---
import BaseLayout from '../layouts/BaseLayout.astro';

const events = [
  { date: '2025年6月29日（日）', title: '川越・狭山平地林観察会', location: '掘兼・上赤坂公園', done: true },
  { date: '2025年7月21日（月・祝日）', title: '小川げんきプラザ周辺観察会', location: '小川げんきプラザ バンガロー下駐車場', done: true },
  { date: '2025年9月15日（月・祝日）', title: '群馬の森公園観察会', location: '群馬の森公園', done: true },
  { date: '2025年10月12日（日）', title: '美の山公園観察会', location: '美の山公園第二駐車場', done: true },
  { date: '2025年11月3日（月・祝日）', title: '秋ヶ瀬公園観察会', location: '秋ヶ瀬公園', done: true },
  { date: '2025年12月7日（日）', title: 'きのこ発表・勉強会', location: '上尾市文化センター', done: true },
  { date: '2026年3月15日（日）', title: 'きのこ栽培勉強会', location: '橋本啓一さんの「あすわの」', done: true },
];
---
<BaseLayout title="行事予定" description="埼玉きのこ研究会の2025年度行事予定。観察会・勉強会のスケジュール。">

  <nav class="text-sm text-text-light mb-4">
    <a href="/" class="hover:text-forest">HOME</a> &gt;
    <span>行事予定</span>
  </nav>

  <h2 class="text-2xl font-bold text-forest border-l-4 border-mushroom pl-3 mb-6">2025年度 行事予定</h2>

  <div class="bg-white rounded-xl shadow-sm p-6 md:p-8 mb-8">
    <h3 class="text-lg font-bold text-bark mb-4">会員各位へのお願い</h3>
    <ul class="text-sm space-y-2 text-text-light">
      <li>各行事には積極的に参加するようお願いいたします。</li>
      <li>住所・電話番号など変更がありましたら事務局までお知らせ下さい。</li>
      <li>野外観察会に参加する場合はできるだけ肌を露出してない服装でお願いいたします。</li>
      <li>観察会では、鑑定に必要数以上は採取しないようお願いいたします。</li>
      <li>自然災害等で行事の開催が危険と判断されるとき、中止する場合があります。連絡はホームページにて行います。</li>
    </ul>
  </div>

  <div class="space-y-4">
    {events.map(ev => (
      <div class={`bg-white rounded-xl shadow-sm p-5 flex flex-col sm:flex-row sm:items-center gap-3 ${ev.done ? 'opacity-75' : 'border-l-4 border-mushroom'}`}>
        <div class="sm:w-56">
          <time class="text-sm font-bold text-bark">{ev.date}</time>
        </div>
        <div class="flex-1">
          <h4 class="font-bold text-forest">{ev.title}</h4>
          <p class="text-sm text-text-light">{ev.location}</p>
        </div>
        {ev.done && <span class="text-xs bg-gray-200 text-text-light px-2 py-1 rounded self-start">終了</span>}
      </div>
    ))}
  </div>

  <p class="text-sm text-text-light mt-6">※ 2026年度の行事予定は決定次第掲載します。</p>

</BaseLayout>
