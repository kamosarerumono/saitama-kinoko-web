---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ページが見つかりません" description="お探しのページは見つかりませんでした。">

  <div class="text-center py-20">
    <p class="text-6xl font-bold text-bark mb-4">404</p>
    <h2 class="text-2xl font-bold text-forest mb-4">ページが見つかりません</h2>
    <p class="text-text-light mb-8">お探しのページは移動または削除された可能性があります。</p>
    <a href="/" class="bg-forest hover:bg-forest-light text-white px-6 py-3 rounded-lg font-bold transition">
      トップページへ戻る
    </a>
  </div>

</BaseLayout>
