---
import BaseLayout from '../layouts/BaseLayout.astro';

const issues = [
  { num: 35, date: '2024年4月30日' },
  { num: 34, date: '2023年4月30日' },
  { num: 33, date: '2020年4月30日' },
  { num: 32, date: '2019年4月30日' },
  { num: 31, date: '2018年4月30日' },
  { num: 30, date: '2017年4月30日' },
  { num: 29, date: '2016年4月30日' },
  { num: 28, date: '2015年4月30日' },
  { num: 27, date: '2014年4月30日' },
  { num: 26, date: '2013年4月30日' },
  { num: 25, date: '2012年4月30日' },
  { num: 24, date: '2011年4月30日' },
  { num: 23, date: '2010年4月30日' },
  { num: 22, date: '2009年4月30日' },
  { num: 21, date: '2008年5月31日' },
  { num: 20, date: '2007年5月31日' },
  { num: 19, date: '2006年4月30日' },
  { num: '17/18', date: '2004年3月25日', combined: true },
  { num: 16, date: '2002年3月25日' },
  { num: 15, date: '2001年3月25日' },
  { num: 14, date: '2000年3月25日' },
  { num: 13, date: '1999年1月15日' },
  { num: 12, date: '1998年1月1日' },
  { num: 11, date: '1997年1月12日' },
  { num: 10, date: '1995年12月20日' },
  { num: '8/9', date: '1994年9月28日', combined: true, note: '十周年記念合併号' },
  { num: 7, date: '1993年9月30日' },
  { num: 6, date: '1992年9月30日' },
  { num: 5, date: '1991年9月30日' },
  { num: 4, date: '1990年9月30日' },
  { num: 3, date: '1989年9月30日' },
  { num: 2, date: '1988年9月30日' },
  { num: 1, date: '1987年9月30日', note: '創刊号' },
];

function issueUrl(num: number | string) {
  const n = typeof num === 'string' ? num.replace('/', '') : String(num).padStart(2, '0');
  return `https://www.ippon.sakura.ne.jp/kaihou_ippon/backnumber/ippon${n}g.${Number(String(num).split('/')[0]) >= 19 ? 'html' : 'htm'}`;
}
---
<BaseLayout title="会報「いっぽん」" description="埼玉きのこ研究会の会報「いっぽん」バックナンバー。1987年の創刊号から現在まで。">

  <nav class="text-sm text-text-light mb-4">
    <a href="/" class="hover:text-forest">HOME</a> &gt;
    <span>会報「いっぽん」</span>
  </nav>

  <h2 class="text-2xl font-bold text-forest border-l-4 border-mushroom pl-3 mb-2">会報「いっぽん」バックナンバー</h2>
  <p class="text-sm text-text-light mb-6">埼玉きのこ研究会の会報。1993年〜現在。<a href="https://www.ippon.sakura.ne.jp/kaihou_ippon/ippon_kiji/simeikaisetu.htm" target="_blank" rel="noopener" class="text-forest underline">誌名解説</a></p>

  <div class="bg-white rounded-xl shadow-sm divide-y">
    {issues.map(issue => (
      <a href={issueUrl(issue.num)}
         target="_blank" rel="noopener"
         class="flex items-center gap-4 px-5 py-4 hover:bg-paper transition">
        <span class="text-forest font-bold w-24">第{issue.num}号</span>
        <span class="text-sm text-text-light">{issue.date}発行</span>
        {issue.note && <span class="text-xs bg-mushroom/10 text-mushroom px-2 py-0.5 rounded ml-auto">{issue.note}</span>}
        {issue.combined && !issue.note && <span class="text-xs bg-gray-100 text-text-light px-2 py-0.5 rounded ml-auto">合併号</span>}
      </a>
    ))}
  </div>

</BaseLayout>
